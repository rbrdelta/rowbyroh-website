{
  "name": "rowbyroh-website",
  "version": "1.0.0",
  "description": "Personal portfolio website showcasing my work and projects",
  "main": "index.html",
  "scripts": {
    "dev": "live-server",
    "format": "prettier --write .",
    "serve": "npx --yes http-server -p 4321 -c-1 --silent .",
    "test": "node --test tests/*.test.mjs",
    "gate:a": "node tests/gate-a.mjs",
    "gate:b": "playwright test --config tests/gate-b/playwright.config.mjs",
    "gate:b:update": "playwright test --config tests/gate-b/playwright.config.mjs --update-snapshots",
    "gate:c": "node tests/gate-c/run-gate-c.mjs",
    "ship": "bash scripts/ship.sh",
    "verify": "bash scripts/verify.sh"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:rbrdelta/rowbyroh-website.git"
  },
  "keywords": ["portfolio", "website", "personal"],
  "author": "rowbyroh",
  "license": "MIT",
  "devDependencies": {}
}